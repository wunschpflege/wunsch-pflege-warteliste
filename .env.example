# ============================================================
#  Wunsch-Pflege GmbH - Wartelistenverwaltung
#  Umgebungsvariablen
# ============================================================

# PostgreSQL-Verbindung.
DATABASE_URL="postgresql://user:password@localhost:5432/wunschpflege?schema=public"

# Geheimer Schluessel fuer die Signierung der Login-Sessions (JWT).
AUTH_SECRET="bitte-einen-langen-zufaelligen-wert-eintragen-min-32-zeichen"

# Gueltigkeitsdauer der Session in Stunden (Standard 8)
SESSION_TTL_HOURS="8"

# PIN des initialen Admin-Accounts (s.admin). NACH dem ersten Login aendern!
SEED_ADMIN_PIN="0000"

# Optional: Demo-/Testdaten beim Seed mit anlegen (true/false)
SEED_DEMO_DATA="true"

# Wird von Railway automatisch gesetzt
PORT="3000"
NODE_ENV="production"
